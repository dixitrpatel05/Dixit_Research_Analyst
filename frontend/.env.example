# Backend base URL used by Next.js rewrites in production (Vercel)
# Optional if Vercel already has Railway integration variables.
# Example: https://your-backend.up.railway.app
BACKEND_API_URL=

# Optional public API URL for client-side direct calls if needed
NEXT_PUBLIC_API_URL=

# Optional alias supported by next.config.js auto-detection
RAILWAY_BACKEND_URL=
